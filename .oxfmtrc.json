{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "semi": true,
  "printWidth": 100,
  "sortPackageJson": false,
  "sortImports": {},
  "ignorePatterns": [
    "lib/**",
    "node_modules/**",
    "public/**",
    "**/*.json",
    "**/*.yml",
    "**/*.yaml",
    "**/*.md",
    "**/*.mdx"
  ]
}
